# ── Proveedor IA por defecto (gemini | groq | deepseek) ──
AI_PROVIDER=groq

# ── Claves API (solo necesitas la del proveedor que uses) ──
# Groq Cloud (gratis) → https://console.groq.com
GROQ_API_KEY=gsk_tu_clave_groq
# Google AI Studio → https://aistudio.google.com
GEMINI_API_KEY=tu_clave_gemini
# DeepSeek → https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-tu_clave_deepseek

# ── URL pública del deploy (Render lo asigna automático) ──
APP_URL=https://tu-app.onrender.com
